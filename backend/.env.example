# Copie este arquivo para .env e preencha os valores reais.
# O arquivo .env nunca deve ser commitado no repositório.

# ─── Banco de dados ───────────────────────────────────────────
POSTGRES_PASSWORD=troque_por_uma_senha_forte

# ─── JWT ──────────────────────────────────────────────────────
# Gere com: openssl rand -base64 48
JWT_SECRET_KEY=gere_uma_chave_aleatoria_de_pelo_menos_32_chars

# ─── Frontend ─────────────────────────────────────────────────
# URL pública do frontend (usada para CORS e links de e-mail)
FRONTEND_URL=https://app.suaacademia.com.br

# ─── SMTP ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seuemail@gmail.com
# Senha de app do Gmail (16 caracteres) — não use a senha da conta
SMTP_PASSWORD=xxxx_xxxx_xxxx_xxxx
SMTP_FROM=seuemail@gmail.com
